## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
bin/
obj/

# Visual Studio cache/options directory
.vs/

# VS Code
.vscode/

# Rider
.idea/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Environment files
.env

# ASP.NET specific
*.db
*.sqlite

# Publish output
publish/

# NuGet
*.nupkg
packages/

# Temporary files
*.tmp
*.temp